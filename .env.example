# ──────────────────────────────────────────────────────────────────────────────
# SMS Personal Assistant — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# --- Twilio (required for real SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- NVIDIA NIM (required for LLM features) ---
# Free key at: https://build.nvidia.com/  (click any model → "Get API Key")
NVIDIA_API_KEY=nvapi-...
# Base URL — change to a self-hosted NIM endpoint if running on-prem
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# Structured extraction (reminder parsing, preference storage)
NIM_MODEL_FAST=meta/llama-3.1-8b-instruct
# Free-form responses (scheduling suggestions, general chat)
NIM_MODEL_CAPABLE=meta/llama-3.3-70b-instruct

# --- Database ---
# SQLite for local dev (default). Swap for postgres:// in production.
DATABASE_URL=sqlite:///./assistant.db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Behavior flags ---
# Set MOCK_SMS=true to print SMS to logs instead of sending via Twilio.
# Defaults to true when TWILIO_ACCOUNT_SID is not set.
MOCK_SMS=true

# OpenAI model to use (gpt-4o-mini is fast + cheap)
OPENAI_MODEL=gpt-4o-mini

# --- App ---
ENVIRONMENT=development
