# ──────────────────────────────────────────────────────────────────────────────
# Personal Assistant — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# --- Twilio (required for real SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- OpenRouter (required for LLM features) ---
# Free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Swap any model — no code changes needed. Examples:
#   openai/gpt-4o-mini               (fast, cheap) — default
#   anthropic/claude-3.5-haiku       (smart, fast) — default capable
#   google/gemini-flash-1.5          (fast, multimodal)
#   meta-llama/llama-3.1-8b-instruct:free  (free tier, may 404)
LLM_MODEL_FAST=openai/gpt-4o-mini
LLM_MODEL_CAPABLE=anthropic/claude-3.5-haiku
# Optional: shown on openrouter.ai/activity for usage tracking
OPENROUTER_SITE_URL=https://yourapp.com
OPENROUTER_SITE_NAME=Personal Assistant

# --- Database ---
# PostgreSQL + pgvector (required for persona and semantic memory features).
# For local dev: docker compose up postgres -d && alembic upgrade head
# For production: use a managed PostgreSQL instance with pgvector extension enabled.
DATABASE_URL=postgresql+asyncpg://operator:operator@localhost:5432/assistant

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Slack (optional — leave blank to disable) ---
# Create an app at https://api.slack.com/apps
#   • Enable Event Subscriptions → Request URL: https://<host>/slack/events
#   • Subscribe to: message.im
#   • Bot token scope: chat:write
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# --- Google OAuth (required for Connections service) ---
# Create at: https://console.cloud.google.com/apis/credentials
#   1. Create OAuth 2.0 Client ID (Web application type)
#   2. Add authorized redirect URI: {BASE_URL}/oauth/callback/google
#   3. Enable Gmail API and Google Calendar API in API Library
# For development: add your email as a test user in the OAuth consent screen
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Twilio Verify (required for SMS OTP during registration) ---
# Create a Verify service at: https://www.twilio.com/console/verify/services
# Copy the Service SID (starts with VA...)
# Leave blank for dev mode (accepts any 6-digit code without sending SMS)
TWILIO_VERIFY_SERVICE_SID=

# --- JWT Auth ---
# IMPORTANT: Change this in production! Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-production
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Brave Search (default web search tool) ---
# Free API key at: https://brave.com/search/api/
# Leave blank to get a fallback message when users ask for web search
BRAVE_API_KEY=

# --- Services ---
# URL where the connections service is running (default for docker-compose)
CONNECTIONS_SERVICE_URL=http://connections:8001
# Dashboard URL for OAuth redirects (where the browser should land after OAuth)
# Default: http://localhost:8000 (API serves built SPA via Docker Compose)
# For Vite dev mode: set to http://localhost:5173
DASHBOARD_URL=http://localhost:8000

# --- Encryption ---
# Required for encrypting sensitive data at rest (OAuth tokens, PII).
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Never rotate this key without a migration script.
ENCRYPTION_KEY=

# --- Public URL (required behind reverse proxy) ---
# Set to your public URL when using ngrok, nginx, or any proxy.
# Twilio signs requests against this URL — must match exactly.
# Example: https://abcd-1234.ngrok-free.app
BASE_URL=

# --- Race timeout ---
# How long to wait for worker result before sending ACK (seconds).
# If the worker responds within this window, user gets a single message.
# If it times out, ACK is sent first, then the worker response follows.
# Default: 8.0 — covers most LLM responses via OpenRouter (typically 2-6s).
# RACE_TIMEOUT_S=8.0

# --- Behavior flags ---
# Set MOCK_SMS=true to print SMS to logs instead of sending via Twilio.
# Defaults to true when TWILIO_ACCOUNT_SID is not set.
MOCK_SMS=true

# --- Proactive Agent (Phase 4) ---
# PROACTIVE_ENABLED=true          # Enable/disable proactive messaging globally
# Platform-wide proactivity defaults (admin can update at runtime via dashboard)
# PROACTIVE_MAX_DAILY_MESSAGES=3        # Max proactive messages per user per day (1-50)
# PROACTIVE_MAX_PER_HOUR=10             # Max proactive messages per user per hour (1-20)
# PROACTIVE_MAX_CATEGORIES_PER_DAY=3    # Max categories selected per day plan (1-9)
# PROACTIVE_QUIET_HOURS_START=22        # Default quiet hours start (0-23, local time)
# PROACTIVE_QUIET_HOURS_END=7           # Default quiet hours end (0-23, local time)
# PROACTIVE_CONTENT_SUPPRESSION=true    # Global toggle: set false to disable content delta suppression (messages always send)

# --- Service Auth ---
# Shared secret for API->connections service auth. Both services must use the same value.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SERVICE_AUTH_TOKEN=

# --- App ---
# ENVIRONMENT=development  # Defaults to 'production'. Set to 'development' to enable debug routes.
