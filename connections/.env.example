# Connections Service Environment Variables

# Database connection string (PostgreSQL recommended for production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/operator

# Fernet encryption key for OAuth tokens and API keys
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Google OAuth credentials (for Gmail/Calendar connections)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/oauth/callback/google

# Slack OAuth credentials (for Slack workspace connections -- NOT the DM bot)
# Create a NEW Slack app at https://api.slack.com/apps with user token scopes:
# channels:read, channels:history, groups:read, groups:history, users:read, team:read
# Enable token rotation under OAuth and Permissions settings
# NOTE: These are separate from SLACK_BOT_TOKEN/SLACK_SIGNING_SECRET used for DM delivery
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8001/oauth/callback/slack

# Main dashboard URL (for OAuth callback redirects)
DASHBOARD_URL=http://localhost:8000

# Comma-separated MCP server URL patterns. Empty = allow all.
# Example: https://mcp.example.com,https://trusted.org
MCP_ALLOWLIST=
